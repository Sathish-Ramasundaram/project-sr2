{
    "name": "sr-store-api",
    "version": "1.0.0",
    "description": "SR Store backend API service",
    "main": "dist/app.js",
    "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "start:worker": "node dist/temporal/worker.js",
    "temporal:worker": "ts-node-dev --respawn --transpile-only src/temporal/worker.ts",
    "db:check": "npm run build && node dist/scripts/checkKnexConnection.js"
  },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "dependencies": {
        "@temporalio/activity": "^1.15.0",
        "@temporalio/client": "^1.15.0",
        "@temporalio/worker": "^1.15.0",
        "@temporalio/workflow": "^1.15.0",
        "bcryptjs": "^3.0.3",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "graphql": "^16.13.1",
        "graphql-yoga": "^5.18.1",
        "knex": "^3.1.0",
        "pg": "^8.16.3",
        "jsonwebtoken": "^9.0.3"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.3.3",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.9.3"
    }
